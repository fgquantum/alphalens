// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER")   // USER | ADMIN
  plan          String    @default("free")   // free | pro | elite
  realBalance   Float     @default(100.0)    // Virtual real cash wallet balance
  arenaTier     String    @default("Silver")  // Silver | Gold | Platinum | Diamond
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  watchlist     WatchlistItem[]
  alerts        Alert[]
  votes         Vote[]
  arenaEntries  ArenaParticipant[]
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model Alert {
  id          String    @id @default(cuid())
  userId      String
  symbol      String
  type        String    // price_above | price_below | alpha_change | volume_spike
  targetValue Float
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  vote      String   // bull | bear
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid()) // SQLite Cuid key placeholder for vToken uniqueness if needed
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String   // info | warn | error
  message   String
  action    String?  // user_delete | setting_change | sql_query | login
  userId    String?
  createdAt DateTime @default(now())
}

model ArenaSeason {
  id           String             @id @default(cuid())
  seasonNumber Int                @unique
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean            @default(false)
  isCompleted  Boolean            @default(false)
  winnerId     String?
  createdAt    DateTime           @default(now())
  participants ArenaParticipant[]
}

model ArenaParticipant {
  id               String                  @id @default(cuid())
  seasonId         String
  userId           String
  tier             String                  // Silver | Gold | Platinum | Diamond
  budget           Float                   // Starting budget
  tickers          String                  // Comma-separated list of selected tickers
  allocationsJSON  String                  // JSON mapping of tickers to allocated percentage (e.g. {"AAPL":20,"NVDA":30...})
  entryPricesJSON  String                  // JSON mapping of starting prices
  currentPricesJSON String                 // JSON mapping of current prices
  hasPaid          Boolean                 @default(false)
  portfolioValue   Float                   @default(0.0)
  avgReturnPct     Float                   @default(0.0)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  season           ArenaSeason             @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyHistory     ArenaDailyPerformance[]

  @@unique([seasonId, userId])
}

model ArenaDailyPerformance {
  id             String           @id @default(cuid())
  participantId  String
  date           DateTime         @default(now())
  portfolioValue Float
  avgReturnPct   Float

  participant    ArenaParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
}

